---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Anthropic 妈妈测试 — Claude API 密钥真伪检测',
  description = '最专业的 Claude API Key 真伪检测平台。黑盒模式识别中转站掺假、模型降级、Token 虚报。anthropic.mom',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Captcha scripts loaded dynamically by CaptchaWidget based on admin config -->
  </head>
  <body class="min-h-screen bg-cream text-ink antialiased">
    <Header />
    <main><slot /></main>
    <Footer />

    <script>
      import { applyI18n } from '../lib/i18n-dom';
      applyI18n();
      window.addEventListener('locale-change', () => applyI18n());
    </script>
  </body>
</html>
