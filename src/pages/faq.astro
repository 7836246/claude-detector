---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

const faqs = [
  { n: 1, q: '检测会消耗我的 Token 吗?', a: '会。每次检测需要向你提供的 endpoint 发送约 19 轮请求,费用大约 $0.02 – $0.30(取决于所选模型)。这是无法避免的 — 必须实际调用上游才能采集到响应特征。' },
  { n: 2, q: '你们会存储我的 API Key 吗?', a: '不会。我们采用黑盒模式,Key 仅在单次请求的内存中使用,检测完成后立即丢弃,不会写入日志、数据库或任何持久化存储。' },
  { n: 3, q: '为什么要约 19 轮请求?', a: '单轮结果有噪声。19 轮请求覆盖模型指纹、token 计费、延迟分布、工具调用、流式格式等多个维度,通过统计方法降低误判率。' },
  { n: 4, q: '检测通过了,是不是 100% 安全?', a: '不是。检测只能识别已知的掺假手法。一个足够精巧的代理理论上可以让所有 probe 通过,但这样做的成本会远高于直接转发官方 API。检测通过意味着在合理成本下值得信任。' },
  { n: 5, q: '检测不通过,一定是假的吗?', a: '大概率是,但不绝对。某些区域路由、特殊部署环境、自定义 system prompt 注入可能产生假阳性。建议换个网络环境重跑,或联系我们复核。' },
  { n: 6, q: '支持哪些模型?', a: '目前支持 Claude Opus 4.6、Sonnet 4.6、Haiku 4.5。后续会逐步增加对更多模型的支持。' },
];
---

<Layout title="常见问题 — Anthropic 妈妈测试">
  <section class="mx-auto max-w-2xl px-6 py-20">
    <h1 class="text-3xl font-bold text-ink" data-i18n="faq.title">常见问题</h1>
    <p class="mt-2 text-sm text-ink-secondary" data-i18n="faq.sub">关于检测原理、安全性和使用方式</p>

    <div class="mt-8 space-y-2">
      {faqs.map((f) => (
        <details class="group rounded-xl border border-sand bg-white transition-colors open:border-sand-dark">
          <summary class="flex cursor-pointer list-none items-start gap-3 px-5 py-4 text-[15px] font-medium text-ink marker:hidden">
            <span class="mt-0.5 text-xs text-terra transition-transform group-open:rotate-90">▶</span>
            <span class="flex-1" data-i18n={`faq.q${f.n}`}>{f.q}</span>
          </summary>
          <div class="border-t border-sand px-5 py-4">
            <p class="pl-6 text-sm leading-relaxed text-ink-secondary" data-i18n={`faq.a${f.n}`}>{f.a}</p>
          </div>
        </details>
      ))}
    </div>
  </section>
</Layout>
