---
import Layout from '../../layouts/Layout.astro';
import Report, { type ReportData } from '../../components/Report.tsx';
import { load } from '../../lib/store';
import { t, detectLocale } from '../../lib/i18n';

export const prerender = false;

interface StoredResult {
  score?: number;
  verdict?: 'genuine' | 'suspicious' | 'fake';
  verdictDetail?: unknown;
  model?: string;
  categories?: unknown[];
  audit?: unknown;
  results?: Array<{ name: string; label: string; [k: string]: unknown }>;
}

const { id } = Astro.params;
const raw = id ? (load(id) as StoredResult | null) : null;
const found = !!raw?.results;
const locale = detectLocale(Astro.request.headers.get('accept-language'));

const reportData: ReportData | null = found && raw
  ? {
      score: raw.score ?? 0,
      verdict: raw.verdict ?? 'suspicious',
      verdictDetail: (raw.verdictDetail ?? null) as ReportData['verdictDetail'],
      model: raw.model ?? '',
      categories: (raw.categories ?? []) as ReportData['categories'],
      audit: (raw.audit ?? null) as ReportData['audit'],
      probes: (raw.results ?? []).map((r, i) => ({
        index: i,
        name: r.name,
        label: r.label,
        result: r as unknown as ReportData['probes'][number]['result'],
      })),
      resultId: id,
    }
  : null;

const pageTitle = found ? `${t('result.title', locale)} — anthropic.mom` : t('result.not_found', locale);
---

<Layout title={pageTitle}>
  <section class="mx-auto max-w-3xl px-6 py-12">
    {reportData ? (
      <Report client:visible data={reportData} locale={locale} />
    ) : (
      <div class="rounded-xl border border-slate-200/70 bg-white/70 p-10 text-center backdrop-blur-sm">
        <div class="text-4xl">😢</div>
        <h1 class="mt-4 text-xl font-bold">{t('result.not_found', locale)}</h1>
        <p class="mt-2 text-sm text-slate-600">
          {t('result.expired', locale)}
        </p>
        <a
          href="/"
          class="mt-6 inline-block rounded-lg bg-indigo-600 px-6 py-2.5 text-sm font-medium text-white shadow-lg shadow-indigo-500/20 hover:shadow-xl"
        >
          {t('result.back_home', locale)}
        </a>
      </div>
    )}
  </section>
</Layout>
