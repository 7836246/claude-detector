# Captcha config is now managed through /admin/settings (stored in SQLite).
# These env vars are optional fallbacks only; leave blank for first-time deploys.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Admin panel password (required — must be set, no safe default).
# Generate with: openssl rand -hex 16
ADMIN_PASSWORD=

# SQLite data directory (absolute path in production)
DATA_DIR=./data

# Set to "0" when the app is NOT behind a trusted reverse proxy, so X-Forwarded-For
# headers from clients are ignored for rate limiting. Default (unset) trusts proxies.
TRUST_PROXY=1

# Set to "1" only for local development to allow probing localhost / private IPs.
# MUST be unset in production (otherwise SSRF guard is disabled).
ALLOW_PRIVATE_TARGETS=
